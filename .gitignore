# ==============================================================================
# .gitignore para Infraestrutura Gentoo / Kernel Scripts
# ==============================================================================

# 1. Arquivos de Backup e Arquivamento (Bloqueio Crítico)
*.tar.zst
*.tar.gz
*.tar.xz
*.bak
*.backup
*.img
*.iso

# 2. Artefatos de Compilação de Kernel (Caso o script rode no diretório errado)
.config
.config.old
Module.symvers
modules.order
*.o
*.ko
*.mod.c
*.mod
.built-in.a
vmlinux
System.map

# 3. Arquivos Temporários de Editores (Vim, Nano, Emacs)
*~
.*.sw[a-p]
.*.swo
DEADJOE
\#*\#

# 4. Logs e Dumps do Sistema
*.log
*.err
*.out
crash_notes/

# 5. Diretórios de IDEs e Ferramentas (VSCode, etc.)
.vscode/
.idea/
*.sublime-workspace

# 6. Lixo de SO Específico (Pendrives montados, etc.)
.DS_Store
Thumbs.db
